import json
import os
from datetime import datetime, date
from typing import List, Dict, Optional

DATA_FILE = "events.json"

# Робота з датами/часом

def parse_date(date_str: str) -> Optional[str]:
    """
    Приймає дату у форматі YYYY-MM-DD.
    Повертає нормалізовану дату (рядок) якщо все ок, або None якщо помилка.
    """
    try:
        dt = datetime.strptime(date_str.strip(), "%Y-%m-%d").date()
        return dt.strftime("%Y-%m-%d")
    except ValueError:
        return None


def parse_time(time_str: str) -> Optional[str]:
    """
    Приймає час у форматі HH:MM.
    Дозволяє порожній рядок (без часу).
    """
    time_str = time_str.strip()
    if time_str == "":
        return ""
    try:
        t = datetime.strptime(time_str, "%H:%M").time()
        return t.strftime("%H:%M")
    except ValueError:
        return None


def event_sort_key(ev: Dict) -> tuple:
    """
    Сортування: дата, потім час (без часу -> в кінець дня).
    """
    ev_date = ev.get("date", "9999-12-31")
    ev_time = ev.get("time", "")
    if ev_time == "":
        ev_time = "99:99"
    return (ev_date, ev_time, ev.get("id", 0))


def today_str() -> str:
    """Повертає сьогоднішню дату у форматі YYYY-MM-DD."""
    return date.today().strftime("%Y-%m-%d")

# Збереження/завантаження

def load_events() -> List[Dict]:
    """
    Завантажує список подій з JSON-файлу.
    Якщо файл відсутній або пошкоджений — повертає порожній список.
    """
    if not os.path.exists(DATA_FILE):
        return []

    try:
        with open(DATA_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            if isinstance(data, list):
                return data
            return []
    except (json.JSONDecodeError, OSError):
        return []


def save_events(events: List[Dict]) -> None:
    """Зберігає список подій у JSON-файл."""
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(events, f, ensure_ascii=False, indent=2)


def next_id(events: List[Dict]) -> int:
    """Генерує наступний ID події."""
    if not events:
        return 1
    return max(ev.get("id", 0) for ev in events) + 1

# Вивід

def print_event(ev: Dict) -> None:
    """Друкує одну подію."""
    ev_id = ev.get("id", "?")
    ev_date = ev.get("date", "????-??-??")
    ev_time = ev.get("time", "")
    ev_title = ev.get("title", "(без назви)")
    ev_note = ev.get("note", "")

    time_part = f"{ev_time} " if ev_time else ""
    print(f"[{ev_id}] {ev_date} {time_part}| {ev_title}")
    if ev_note.strip():
        print(f"    Нотатка: {ev_note}")


def print_help() -> None:
    print("Команди бота 'Організатор подій':")
    print("  help                - показати список команд")
    print("  додати              - додати нову подію")
    print("  список              - показати всі події")
    print("  сьогодні            - показати події на сьогодні")
    print("  наступні [N]        - показати найближчі N подій (за замовчуванням 5)")
    print("  пошук <текст>       - знайти події за назвою або нотаткою")
    print("  видалити <id>       - видалити подію за ID")
    print("  очистити            - видалити всі події")
    print("  вихід               - завершити роботу програми")

    print("\nФормати введення:")
    print("  Дата: YYYY-MM-DD (наприклад 2026-03-20)")
    print("  Час: HH:MM (наприклад 14:30) або Enter якщо без часу")

# Обробники команд

def handle_add(events: List[Dict]) -> None:
    """
    Додає подію через діалог:
    - назва
    - дата
    - час (опціонально)
    - нотатка (опціонально)
    """
    print("Додавання події.")
    title = input("Назва події: ").strip()
    if not title:
        print("Назва не може бути порожньою.")
        return

    while True:
        d = input("Дата (YYYY-MM-DD): ").strip()
        d_ok = parse_date(d)
        if d_ok is None:
            print("Неправильний формат дати. Приклад: 2026-03-20")
            continue
        break

    while True:
        t = input("Час (HH:MM) або Enter якщо без часу: ").strip()
        t_ok = parse_time(t)
        if t_ok is None:
            print("Неправильний формат часу. Приклад: 14:30 або Enter.")
            continue
        break

    note = input("Нотатка (опціонально): ").strip()

    ev = {
        "id": next_id(events),
        "title": title,
        "date": d_ok,
        "time": t_ok,  # "" якщо без часу
        "note": note,
        "created_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    }

    events.append(ev)
    events.sort(key=event_sort_key)
    save_events(events)
    print("Подію додано:")
    print_event(ev)


def handle_list(events: List[Dict]) -> None:
    """Показує всі події."""
    if not events:
        print("Поки що немає жодної події. Додай через команду 'додати'.")
        return

    print(f"Усього подій: {len(events)}")
    for ev in sorted(events, key=event_sort_key):
        print_event(ev)


def handle_today(events: List[Dict]) -> None:
    """Показує події на сьогодні."""
    t = today_str()
    todays = [ev for ev in events if ev.get("date") == t]
    if not todays:
        print(f"На сьогодні ({t}) подій немає.")
        return

    print(f"Події на сьогодні ({t}): {len(todays)}")
    for ev in sorted(todays, key=event_sort_key):
        print_event(ev)


def handle_next(events: List[Dict], n: int = 5) -> None:
    """Показує найближчі n подій, починаючи від сьогодні."""
    if not events:
        print("Подій немає.")
        return

    t = today_str()
    future = [ev for ev in events if ev.get("date", "0000-00-00") >= t]
    future.sort(key=event_sort_key)

    if not future:
        print("Немає майбутніх подій.")
        return

    n = max(1, n)
    print(f"Найближчі події (показую {min(n, len(future))}):")
    for ev in future[:n]:
        print_event(ev)


def handle_search(events: List[Dict], query: str) -> None:
    """Пошук за підрядком у назві або нотатці (без регістру)."""
    q = query.strip().lower()
    if not q:
        print("Вкажи текст для пошуку. Приклад: пошук матаналіз")
        return

    found = []
    for ev in events:
        title = ev.get("title", "").lower()
        note = ev.get("note", "").lower()
        if q in title or q in note:
            found.append(ev)

    if not found:
        print("Нічого не знайдено.")
        return

    found.sort(key=event_sort_key)
    print(f"Знайдено подій: {len(found)}")
    for ev in found:
        print_event(ev)


def handle_delete(events: List[Dict], id_str: str) -> None:
    """Видаляє подію за ID."""
    id_str = id_str.strip()
    if not id_str.isdigit():
        print("ID має бути числом. Приклад: видалити 3")
        return

    ev_id = int(id_str)
    idx = None
    for i, ev in enumerate(events):
        if ev.get("id") == ev_id:
            idx = i
            break

    if idx is None:
        print(f"Події з ID={ev_id} не знайдено.")
        return

    removed = events.pop(idx)
    save_events(events)
    print("Видалено подію:")
    print_event(removed)


def handle_clear(events: List[Dict]) -> None:
    """Видаляє всі події з підтвердженням."""
    if not events:
        print("Список подій і так порожній.")
        return

    confirm = input("Точно видалити ВСІ події? (так/ні): ").strip().lower()
    if confirm != "так":
        print("Скасовано.")
        return

    events.clear()
    save_events(events)
    print("Усі події видалено.")

# Основний цикл програми

def main() -> None:
    events = load_events()
    events.sort(key=event_sort_key)

    print("Бот 'Організатор подій' запущено.")
    print("Напиши 'help' щоб побачити команди.\n")

    while True:
        user_input = input("> ").strip()

        if user_input == "":
            continue

        parts = user_input.split(" ", 1)
        cmd = parts[0].lower()
        args = parts[1] if len(parts) > 1 else ""

        if cmd == "help":
            print_help()

        elif cmd == "додати":
            handle_add(events)

        elif cmd == "список":
            handle_list(events)

        elif cmd == "сьогодні":
            handle_today(events)

        elif cmd == "наступні":
            n = 5
            if args.strip():
                if args.strip().isdigit():
                    n = int(args.strip())
                else:
                    print("Формат: наступні або наступні 10")
                    continue
            handle_next(events, n)

        elif cmd == "пошук":
            handle_search(events, args)

        elif cmd == "видалити":
            handle_delete(events, args)

        elif cmd == "очистити":
            handle_clear(events)

        elif cmd == "вихід":
            print("До побачення")
            break

        else:
            print("Невідома команда. Напиши 'help'.")


if __name__ == "__main__":
    main()
